# Copy to .env for local development. Do not commit real secrets.

# Backend
VANTAGE_APP_MODE=
VANTAGE_BACKEND_HOST=127.0.0.1
VANTAGE_BACKEND_PORT=8000
VANTAGE_CAPTURE_INTERVAL_SECONDS=60

# Runtime directories. Leave empty to use platform defaults.
VANTAGE_DATA_DIR=
VANTAGE_CONFIG_DIR=
VANTAGE_HISTORY_DIR=
VANTAGE_LOG_DIR=
VANTAGE_PLOT_DIR=
VANTAGE_CACHE_DIR=
VANTAGE_RUNTIME_DIR=
VANTAGE_MIGRATION_DIR=

# Optional capture/location settings.
VANTAGE_LEGACY_MEDIA_ROOT=
VANTAGE_PHOTO_ROOTS=
VANTAGE_STATIC_LATITUDE=
VANTAGE_STATIC_LONGITUDE=

# LLM provider fallback. The in-app Settings screen is preferred for normal use.
CLIPROXYAPI_BASE_URL=http://127.0.0.1:8317/v1
CLIPROXYAPI_API_KEY=
CLIPROXYAPI_MODEL=

CLIPROXYAPI_SECONDARY_BASE_URL=http://127.0.0.1:8045/v1
CLIPROXYAPI_SECONDARY_API_KEY=
CLIPROXYAPI_SECONDARY_MODEL=

CLIPROXYAPI_FALLBACK_BASE_URL=https://api.siliconflow.cn/v1
CLIPROXYAPI_FALLBACK_API_KEY=
CLIPROXYAPI_FALLBACK_MODEL=

# Optional transcription provider.
VANTAGE_TRANSCRIBE_BASE_URL=
VANTAGE_TRANSCRIBE_API_KEY=
VANTAGE_TRANSCRIBE_MODEL=

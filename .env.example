# Copy to .env for local development. Do not commit real secrets.

# Backend
VANTAGE_BACKEND_HOST=127.0.0.1
VANTAGE_BACKEND_PORT=8000
VANTAGE_CAPTURE_INTERVAL_SECONDS=60

# Runtime directories. Leave empty to use platform defaults.
VANTAGE_DATA_DIR=
VANTAGE_CONFIG_DIR=
VANTAGE_HISTORY_DIR=
VANTAGE_LOG_DIR=
VANTAGE_PLOT_OUTPUT_DIR=

# Optional capture/location settings.
VANTAGE_PHOTO_ROOTS=
VANTAGE_STATIC_LATITUDE=
VANTAGE_STATIC_LONGITUDE=

# LLM provider examples. Fill only the providers you use.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=

LOCAL_PROXY_BASE_URL=http://127.0.0.1:4000/v1
LOCAL_PROXY_API_KEY=
LOCAL_PROXY_MODEL=

SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=

# Optional transcription provider.
VANTAGE_TRANSCRIBE_BASE_URL=
VANTAGE_TRANSCRIBE_API_KEY=
VANTAGE_TRANSCRIBE_MODEL=

# 这是一个python库的gitignore文件
# 忽略 YOLO 训练得到的权重文件
*.pt
# 用于忽略一些不需要提交到git的文件
icon.ico
main.exe
# 忽略logs/photos/文件夹
logs/photos/

#忽略所有文件夹下的knowledge_base.json
**/knowledge_base.json

# 忽略logs/photos/文件夹
logs/screenshots/
# 忽略test/文件夹
# tests/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
target/

# IPython Notebook
.ipynb_checkpoints

# pyenv
.python-version

# celery beat schedule file
celerybeat-schedule

# SageMath parsed files
*.sage.py

# Environments
.env
.env.*
!.env.example
.venv
.venv-backend-runtime-gpu/
.local-python-*/
env/
venv/
ENV/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# End of https://www.gitignore.io/api/python
your_image*.jpg
src/AI_Prediction/*.png
plot_outputs/
history/
**/tempCodeRunnerFile.py
src/AI_Prediction/data/*.csv
.vscode/launch.json
src/scripts/download_model_helper.py
results.csv
data/mi_fiteness_data/
data/zepplift_data/

# Claude Code
.claude/

# Agent skills (superpowers)
.agents/
logs/
output/
tmp/
cache/
migration/
runtime/
config/
src/webapp/electron-dist/

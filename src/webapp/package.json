{
  "name": "vantage",
  "private": true,
  "version": "1.0.59",
  "description": "Vantage Electron Desktop Application",
  "main": "main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/vite-build.mjs",
    "test": "node --test vite.config.test.js package.test.js \"src/**/*.test.js\"",
    "check": "npm run lint && npm run test && npm run build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "node scripts/vite-build.mjs && electron-builder",
    "electron:package": "electron-builder",
    "electron:start": "electron ."
  },
  "dependencies": {
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.2",
    "lucide-react": "^0.577.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.1.0",
    "electron": "^42.6.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^16.5.0",
    "vite": "^7.2.4",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.vantage.app",
    "productName": "Vantage",
    "afterPack": "./scripts/sign-mac-ad-hoc.cjs",
    "npmRebuild": false,
    "directories": {
      "output": "electron-dist"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "build-info.json",
      "preload.cjs",
      "src/utils/**/*.cjs",
      "!node_modules/**/*",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "../../build/backend-runtime/stage/VantageBackend",
        "to": "backend-runtime/VantageBackend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "../../icon.png",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.healthcare-fitness"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Vantage",
      "deleteAppDataOnUninstall": false,
      "warningsAsErrors": false,
      "customNsisBinary": {
        "url": "https://github.com/SoundSafari/NSISBI-ElectronBuilder/releases/download/1.0.0/nsisbi-electronbuilder-3.10.3.7z",
        "checksum": "374cfc092fd1bd1898472df627549ecc165b0d6ba88e82deba085673aec95336"
      }
    }
  }
}
